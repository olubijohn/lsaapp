generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                     String    @id @default(cuid())
  cr69d_studentid        String    @unique
  cr69d_title            String?
  cr69d_gender           String?
  cr69d_level            String?
  cr69d_instucode        String?
  cr69d_studentactive    Boolean   @default(true)
  cr69d_totaloutstanding Float     @default(0)
  cr69d_emailaddress     String?
  cr69d_guardianname     String?
  cr69d_guardianphone    String?
  cr69d_guardianwhatsapp String?
  cr69d_address          String?
  cr69d_age              Int?
  cr69d_section          String?
  cr69d_legacyregno      String?
  cr69d_datejoined       DateTime?
  cr69d_medication       String?
  cr69d_sportweartype    String?
  cr69d_contactmethod    String?
  cr69d_sessionjoined    String?
  cr69d_termjoined       String?
  cr69d_bus_subcriber    Boolean   @default(false)
  cr69d_sms_subscriber   Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([cr69d_instucode])
  @@index([cr69d_level])
}
